# Keep line endings consistent across OSes. Files mounted into the Linux
# containers (shell scripts, configs) MUST stay LF — CRLF breaks them with
# "bad interpreter" / parse errors. Default everything to LF on checkout.
* text=auto eol=lf

# Be explicit for the files consumed inside containers.
*.sh         text eol=lf
*.conf       text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.xml        text eol=lf
*.py         text eol=lf
*.json       text eol=lf
*.env        text eol=lf
Dockerfile   text eol=lf

# Binary assets — never touch.
*.jar  binary
*.zip  binary
*.png  binary
*.jpg  binary
*.gz   binary
